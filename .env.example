# Required: URL of your self-hosted mem0 server
MEM0_BASE_URL=https://mem0.example.com

# Required: API key for authentication
MEM0_API_KEY=your-api-key-here

# Optional: override auto-detected user ID (defaults to $USER)
# MEM0_USER_ID=

# Optional: override auto-detected project ID (defaults to git remote slug)
# MEM0_PROJECT_ID=
